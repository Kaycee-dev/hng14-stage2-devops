# ==============================================================================
# hng14 stage2 devops - runtime configuration
# Copy to `.env` and fill real values locally. Never commit `.env`.
# ==============================================================================

# --- Compose / topology ---
COMPOSE_PROJECT_NAME=hng14-stage2-devops
DEPLOY_NETWORK_NAME=stage2-internal
DEPLOY_HEALTH_TIMEOUT_SECONDS=60

# --- Frontend ---
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
FRONTEND_API_BASE_URL=http://api:8000

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
JOB_QUEUE_NAME=jobs

# --- Redis (shared by api + worker) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=REPLACE_ME_WITH_LOCAL_PASSWORD

# --- Worker ---
WORKER_POLL_TIMEOUT_SECONDS=5
WORKER_SIMULATED_DELAY_SECONDS=2

# --- Image publishing (used by CI and compose image tags) ---
REGISTRY_HOST=localhost
REGISTRY_PORT=5000
IMAGE_NAMESPACE=hng14-stage2-devops
IMAGE_TAG=latest

# --- Deploy target (used by CI deploy stage; do not set locally) ---
DEPLOY_SSH_HOST=REPLACE_ME
DEPLOY_SSH_PORT=22
DEPLOY_SSH_USER=REPLACE_ME
DEPLOY_APP_DIR=/opt/hng14-stage2-devops

# --- GitHub Actions secret placeholders (set as repo secrets, not here) ---
DEPLOY_SSH_PRIVATE_KEY=REPLACE_ME_AS_GITHUB_SECRET
